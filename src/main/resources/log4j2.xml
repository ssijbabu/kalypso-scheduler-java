<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>
    </Appenders>
    <Loggers>
        <!-- Operator SDK: INFO so reconciler lifecycle events are visible -->
        <Logger name="io.javaoperatorsdk" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <!-- Application code: DEBUG for local development -->
        <Logger name="io.kalypso" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <!-- Fabric8 client: WARN to suppress routine HTTP traffic -->
        <Logger name="io.fabric8" level="WARN" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <Root level="INFO">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>
